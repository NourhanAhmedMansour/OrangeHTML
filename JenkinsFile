pipeline {
    agent any  

    environment {
        
        NODE_ENV = 'production'
    }

    stages {
        stage('Checkout') {
            steps {
                
                git 'https://github.com/NourhanAhmedMansour/OrangeHTML.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                
                script {
                    sh 'npm install'  
                }
            }
        }

        stage('Run Tests') {
            steps {
               
                script {
                    sh 'npx playwright test'
                }
            }
        }

        stage('Deploy') {
            steps {
                
                echo 'Deploying to production environment...'
                
            }
        }
    }

    post {
        always {
           
            echo 'Cleaning up workspace...'
        }

        success {
           
            echo 'Build succeeded!'
        }

        failure {
          
            echo 'Build failed!'
        }
    }
}
